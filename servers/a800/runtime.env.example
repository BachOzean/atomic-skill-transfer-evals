# Source from the repository root:
#   source servers/a800/runtime.env.example

export RUN_ROOT=/data/home/${USER}/run
export OUTPUTS_ROOT=${RUN_ROOT}/evals
export CACHE_ROOT=${RUN_ROOT}/.cache
export TMPDIR=${RUN_ROOT}/tmp

export CONDA_ENV_NAME=verl_cpython
export CONDA_ROOT=/data/apps/miniforge3/25.11.0-1
export LM_EVAL_PYTHON=${RUN_ROOT}/.venvs/lm_eval_overlay/bin/python
export FLASH_ATTN_OVERLAY=${RUN_ROOT}/vendor/verl-main/.flash_attn_sm80_overlay

export BASE_MODEL_PATH=${RUN_ROOT}/models/Qwen3-1.7B
export GPQA_LOCAL_DATASET_DIR=${RUN_ROOT}/data/gpqa

export BACKEND=vllm
export BATCH_SIZE=auto
export TENSOR_PARALLEL_SIZE=1
export GPU_MEMORY_UTILIZATION=0.90
export MAX_MODEL_LEN=40960
export MAX_GEN_TOKS=32768
export MAX_NUM_SEQS=8
export SWAP_SPACE=8

export NUM_FEWSHOT=0
export TEMPERATURE=1.0
export TOP_P=0.95
export TOP_K=0
export MIN_P=0
export SEED=7
export APPLY_CHAT_TEMPLATE=true
export FEWSHOT_AS_MULTITURN=false
export ENABLE_THINKING=true
export SYSTEM_INSTRUCTION=__AUTO__
export SUMMARIZE=true
